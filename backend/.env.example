# Copy this file to backend/.env and fill in values.
# The demo also runs with NONE of these set — it uses a deterministic offline
# fallback for the AI and a simulated tx hash for the chain.

# ── Chainlink Confidential AI (Attester) ──────────────────────────────────────
# Set CHAINLINK_AI_URL to route the live backend through the Confidential AI
# Attester (the $4k prize path). If unset, falls back to OpenAI; if no keys at
# all, the deterministic offline fallback is used.
CHAINLINK_AI_URL=https://confidential-ai-dev-preview.cldev.cloud/v1/inference
CHAINLINK_AI_API_KEY=your_chainlink_ai_key

# Optional OpenAI fallback (used only when CHAINLINK_AI_URL is not set)
OPENAI_API_KEY=your_openai_key

# ── Employee verification (mock HR service) ───────────────────────────────────
HR_API_KEY=mock-key-for-demo
HR_API_URL=http://localhost:3002/verify

# ── On-chain attestation (Ethereum Sepolia) ──────────────────────────────────
# Set all three to write REAL attestations on-chain (the "Connect the World"
# path). With DEPLOYER_PRIVATE_KEY empty, the backend returns a simulated tx
# hash and nothing is written on-chain.
# Fund the wallet with Sepolia ETH, then optionally run: node seed-onchain.js
CONTRACT_ADDRESS=0x2aa4206aa0b9d2434fa96c5330c17fc23709f597
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
DEPLOYER_PRIVATE_KEY=your_funded_sepolia_wallet_private_key

# ── Hedera dual-layer audit (HCS topic + HTS NFT receipt) ─────────────────────
# Create a testnet account at https://portal.hedera.com, then run once:
#   node hedera-setup.js
# and paste the printed HEDERA_TOPIC_ID / HEDERA_TOKEN_ID back here.
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=your_hedera_ecdsa_hex_key
HEDERA_TOPIC_ID=
HEDERA_TOKEN_ID=
